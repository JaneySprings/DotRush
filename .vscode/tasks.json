{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "tsc: watch",
            "type": "shell",
            "command": "tsc",
            "args": ["-w", "-p", "${workspaceFolder}/src/VSCode"],
            "isBackground": true,
            "problemMatcher": ["$tsc-watch"]
        },
        {
            "label": "vsix",
            "command": "dotnet",
            "type": "process",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "args": ["cake", "--target=vsix", "--configuration=release"]
        },
        {
            "label": "build:dotnet",
            "type": "shell",
            "command": "dotnet build ./src/DotRush.sln -c Release",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build:ext",
            "type": "npm",
            "script": "package",
            "problemMatcher": []
        },
        {
            "label": "build:all",
            "dependsOn": ["build:dotnet", "build:ext", "tsc: watch"],
            "dependsOrder": "sequence"
        }
    ]
}